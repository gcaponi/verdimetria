# Copia questo file in .env e riempilo con le tue credenziali.
# NON committare mai il file .env reale (aggiungilo a .gitignore).

# Copernicus Data Space Ecosystem — registrazione gratuita su:
# https://dataspace.copernicus.eu/
# Poi: Dashboard -> genera un OAuth client per ottenere queste due chiavi.
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# Backend Django locale
DJANGO_SECRET_KEY=change-me-in-production-with-at-least-32-bytes
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://verdimetria.cais.uno

# PostgreSQL/PostGIS locale (porta host 5433)
POSTGRES_DB=verdimetria
POSTGRES_USER=verdimetria
POSTGRES_PASSWORD=verdimetria-local
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Queue locale (porta host 6380)
REDIS_URL=redis://127.0.0.1:6380/0

# AI Insights esclusivamente server-side
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# Object storage S3-compatible (Cloudflare R2 EU, AWS S3 o equivalente)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=verdimetria-production
S3_REGION=auto

# Basemap/geocoding frontend: chiave pubblica, ma protetta per origin
VITE_MAPTILER_API_KEY=

# Weather enterprise opzionale
METEOMATICS_USERNAME=
METEOMATICS_PASSWORD=

# Immagini/DEM premium opzionali: attivare un provider alla volta
PL_API_KEY=
UP42_USERNAME=
UP42_PASSWORD=
VANTOR_API_KEY=
OPENTOPOGRAPHY_API_KEY=

# Email transazionale, billing e observability
POSTMARK_SERVER_TOKEN=
DEFAULT_FROM_EMAIL=
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
SENTRY_DSN=
VITE_SENTRY_DSN=

# Deploy/API Cloudflare; usare token con permessi minimi
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
